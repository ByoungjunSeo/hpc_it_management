function lookupIp(ip) {
    if (!ip || !ip.trim()) {
        document.getElementById('ipMatchResult').style.display = 'none';
        return;
    }
    fetch('/discovery/lookup-ip?ip=' + encodeURIComponent(ip.trim()))
    .then(function(r) { return r.json(); })
    .then(function(data) {
        var container = document.getElementById('ipMatchResult');
        if (!data.results || data.results.length === 0) {
            container.innerHTML = '<div class="alert" style="background:#fff3cd; border:1px solid #ffc107; padding:8px 12px; border-radius:6px; font-size:13px;">등록된 자산 없음 - 이 IP에 매칭되는 자산이 없습니다.</div>';
            container.style.display = '';
            return;
        }
        var html = '<div style="background:#d4edda; border:1px solid #28a745; padding:12px; border-radius:6px;">';
        html += '<strong style="color:#155724;">매칭된 자산 정보</strong>';
        data.results.forEach(function(r) {
            html += '<div style="margin-top:8px; padding:8px; background:white; border-radius:4px;">';
            html += '<span class="badge badge-success">등록됨</span> ';
            html += '<strong>' + escapeHtml(r.asset_number || '') + '</strong> ';
            html += escapeHtml(r.model_name || '') + ' (' + escapeHtml(r.manufacturer || '') + ')';
            html += ' <a href="/assets/' + r.asset_id + '" target="_blank" style="font-size:12px;">[상세]</a>';
            if (r.credentials && r.credentials.length > 0) {
                html += '<div style="margin-top:6px; font-size:13px;">';
                html += '<strong>등록된 자격증명:</strong>';
                html += '<table style="margin-top:4px; font-size:12px; width:100%;"><thead><tr><th>유형</th><th>사용자</th><th>비밀번호</th><th></th></tr></thead><tbody>';
                r.credentials.forEach(function(c) {
                    html += '<tr>';
                    html += '<td><span class="badge badge-info">' + escapeHtml(c.credential_type) + '</span></td>';
                    html += '<td>' + escapeHtml(c.username) + '</td>';
                    html += '<td><code>' + escapeHtml(c.password || '') + '</code></td>';
                    html += '<td><button class="btn btn-sm btn-outline" onclick="useCredential(\'' + escapeHtml(c.username) + '\', \'' + escapeHtml(c.password || '') + '\')">이 계정 사용</button></td>';
                    html += '</tr>';
                });
                html += '</tbody></table></div>';
            }
            html += '</div>';
        });
        html += '</div>';
        container.innerHTML = html;
        container.style.display = '';
    })
    .catch(function(err) { console.error('IP lookup error:', err); });
}

function useCredential(username, password) {
    document.getElementById('sshUser').value = username;
    document.getElementById('sshPassword').value = password;
}

function startManualScan() {
    var mode = document.getElementById('scanMode').value;
    var user = document.getElementById('sshUser').value;
    var password = document.getElementById('sshPassword').value;
    var port = document.getElementById('sshPort').value;

    document.getElementById('manualScanBtn').disabled = true;
    document.getElementById('manualScanBtn').textContent = '스캔 중...';
    document.getElementById('manualScanProgress').style.display = '';
    document.getElementById('manualScanResults').style.display = 'none';
    document.getElementById('manualProgressFill').style.width = '0%';
    document.getElementById('manualProgressText').textContent = '스캔 시작...';

    var url, body;

    if (mode === 'single') {
        var ip = document.getElementById('scanIp').value;
        if (!ip) { alert('IP 주소를 입력하세요.'); resetManualScanBtn(); return; }
        url = '/discovery/scan';
        body = { ip: ip, user: user, password: password, port: port };
    } else {
        var startIp = document.getElementById('startIp').value;
        var endIp = document.getElementById('endIp').value;
        if (!startIp || !endIp) { alert('IP 범위를 입력하세요.'); resetManualScanBtn(); return; }
        url = '/discovery/scan-range';
        body = { start_ip: startIp, end_ip: endIp, user: user, password: password, port: port };
    }

    fetch(url, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body)
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
        var results = Array.isArray(data) ? data : [data];
        manualScanResultsData = results;
        document.getElementById('manualProgressFill').style.width = '100%';
        document.getElementById('manualProgressText').textContent = '완료! ' + results.length + '개 호스트 스캔됨';

        if (mode === 'range') {
            var lookupPromises = results.map(function(r) {
                return fetch('/discovery/lookup-ip?ip=' + encodeURIComponent(r.ip))
                    .then(function(resp) { return resp.json(); })
                    .then(function(d) { r._matchInfo = d.results || []; })
                    .catch(function() { r._matchInfo = []; });
            });
            Promise.all(lookupPromises).then(function() {
                renderManualResults(results);
                resetManualScanBtn();
            });
        } else {
            renderManualResults(results);
            resetManualScanBtn();
        }
    })
    .catch(function(err) {
        document.getElementById('manualProgressText').textContent = '오류: ' + err.message;
        resetManualScanBtn();
    });
}

function resetManualScanBtn() {
    document.getElementById('manualScanBtn').disabled = false;
    document.getElementById('manualScanBtn').textContent = '스캔 시작';
}

function renderManualResults(results) {
    document.getElementById('manualScanResults').style.display = '';
    var html = '';

    results.forEach(function(r, idx) {
        var statusBadge = '';
        if (r.status === 'success') statusBadge = '<span class="badge badge-success">성공</span>';
        else if (r.status === 'auth_failed') statusBadge = '<span class="badge badge-warning">인증 실패</span>';
        else if (r.status === 'unreachable') statusBadge = '<span class="badge badge-danger">접속 불가</span>';
        else statusBadge = '<span class="badge badge-secondary">' + r.status + '</span>';

        var matchBadge = '';
        if (r._matchInfo && r._matchInfo.length > 0) {
            matchBadge = ' <span class="badge badge-info">등록됨</span>';
        } else if (r._matchInfo) {
            matchBadge = ' <span class="badge badge-secondary">미등록</span>';
        }

        html += '<div style="padding:16px; border-bottom:1px solid var(--border);">';
        html += '<div class="d-flex justify-between align-center mb-1">';
        html += '<strong>' + escapeHtml(r.ip) + '</strong> ' + statusBadge + matchBadge;
        if (r.status === 'success') {
            html += ' <button class="btn btn-sm btn-success" onclick="applyManualResult(' + idx + ')">자산에 반영</button>';
        }
        html += '</div>';

        if (r.hostname) html += '<p>호스트명: ' + escapeHtml(r.hostname) + '</p>';
        if (r.totalMemory) html += '<p>총 메모리: ' + escapeHtml(r.totalMemory) + '</p>';

        if (r.modules && r.modules.length > 0) {
            html += '<table style="margin-top:8px;"><thead><tr><th>유형</th><th>모델</th><th>용량</th><th>수량</th><th>사양</th></tr></thead><tbody>';
            r.modules.forEach(function(m) {
                html += '<tr><td>' + escapeHtml(m.module_type) + '</td><td>' + escapeHtml(m.model || '-') + '</td><td>' + escapeHtml(m.capacity || '-') + '</td><td>' + (m.count || 1) + '</td><td>' + escapeHtml(m.specification || '-') + '</td></tr>';
            });
            html += '</tbody></table>';
        }

        if (r.error) html += '<p class="text-muted" style="font-size:12px;">오류: ' + escapeHtml(r.error) + '</p>';
        html += '</div>';
    });

    document.getElementById('manualResultsList').innerHTML = html;
}

function applyManualResult(idx) {
    var r = manualScanResultsData[idx];
    if (!r || r.status !== 'success') return;

    fetch('/discovery/apply', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ ip: r.ip, hostname: r.hostname, modules: r.modules, create_new: true })
    })
    .then(function(res) { return res.json(); })
    .then(function(data) {
        if (data.success) {
            alert('자산이 등록/업데이트되었습니다. (ID: ' + data.asset_id + ')');
        } else {
            alert('오류: ' + (data.error || '알 수 없는 오류'));
        }
    })
    .catch(function(err) { alert('오류: ' + err.message); });
}

function applyAllManualResults() {
    var successResults = manualScanResultsData.filter(function(r) { return r.status === 'success'; });
    if (successResults.length === 0) { alert('반영할 결과가 없습니다.'); return; }
    if (!confirm(successResults.length + '개 호스트를 자산에 반영하시겠습니까?')) return;

    var promises = successResults.map(function(r) {
        return fetch('/discovery/apply', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ ip: r.ip, hostname: r.hostname, modules: r.modules, create_new: true })
        }).then(function(res) { return res.json(); });
    });

    Promise.all(promises).then(function(results) {
        var ok = results.filter(function(r) { return r.success; }).length;
        alert(ok + '/' + results.length + '개 자산이 반영되었습니다.');
    });
}
</script>

